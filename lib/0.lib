local Library = {}

local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")

local Theme = {
MainBG = Color3.fromRGB(45, 45, 45),
TopBarBG = Color3.fromRGB(45, 45, 45),
Separator = Color3.fromRGB(35, 35, 35),
InputBG = Color3.fromRGB(35, 35, 35),
ButtonActive = Color3.fromRGB(60, 60, 60),
ButtonDisabled = Color3.fromRGB(45, 45, 45),
TextWhite = Color3.fromRGB(240, 240, 240),
TextDim = Color3.fromRGB(150, 150, 150),
Border = Color3.fromRGB(25, 25, 25),
Highlight = Color3.fromRGB(80, 160, 220)
}

local tweenInfo = TweenInfo.new(0.25, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)

local function ApplyStroke(parent, color)
local stroke = Instance.new("UIStroke")
stroke.Color = color or Theme.Border
stroke.Thickness = 1
stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
stroke.Parent = parent
return stroke
end

local function ApplyFontLogic(element, text)
element.Text = text
if text == "▼" or text == "▲" or text == "✓" then
element.Font = Enum.Font.Arcade
element.TextSize = 10
else
element.Font = Enum.Font.SourceSans
element.TextSize = 13
end
end

function Library:CreateWindow(config)
local Window = {
Elements = {},
DropdownFrames = {},
Title = config.Title or "UI Library",
Size = config.Size or UDim2.new(0, 250, 0, 300)
}

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "CustomUILibrary"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.Parent = Players.LocalPlayer:WaitForChild("PlayerGui")
Window.ScreenGui = ScreenGui

local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = Window.Size
MainFrame.Position = UDim2.new(0.5, -Window.Size.X.Offset / 2, 0.5, -Window.Size.Y.Offset / 2)
MainFrame.BackgroundColor3 = Theme.MainBG
MainFrame.BorderSizePixel = 0
MainFrame.ClipsDescendants = true
MainFrame.Parent = ScreenGui
ApplyStroke(MainFrame)
Window.MainFrame = MainFrame

local GlobalCanvas = Instance.new("CanvasGroup")
GlobalCanvas.Size = UDim2.new(1, 0, 1, 0)
GlobalCanvas.BackgroundTransparency = 1
GlobalCanvas.Parent = MainFrame

local TopBar = Instance.new("Frame")
TopBar.Size = UDim2.new(1, 0, 0, 28)
TopBar.BackgroundColor3 = Theme.TopBarBG
TopBar.BorderSizePixel = 0
TopBar.ZIndex = 3
TopBar.Parent = GlobalCanvas

local TopLine = Instance.new("Frame")
TopLine.Size = UDim2.new(1, 0, 0, 1)
TopLine.Position = UDim2.new(0, 0, 1, 0)
TopLine.BackgroundColor3 = Theme.Separator
TopLine.BorderSizePixel = 0
TopLine.ZIndex = 3
TopLine.Parent = TopBar

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, -60, 1, 0)
Title.Position = UDim2.new(0, 8, 0, 0)
Title.BackgroundTransparency = 1
Title.Text = Window.Title
Title.TextColor3 = Theme.TextWhite
Title.Font = Enum.Font.SourceSans
Title.TextSize = 14
Title.TextXAlignment = Enum.TextXAlignment.Left
Title.ZIndex = 4
Title.Parent = TopBar

local CloseBtn = Instance.new("TextButton")
CloseBtn.Size = UDim2.new(0, 28, 0, 28)
CloseBtn.Position = UDim2.new(1, -28, 0, 0)
CloseBtn.BackgroundTransparency = 1
CloseBtn.Text = "×"
CloseBtn.TextColor3 = Theme.TextWhite
CloseBtn.Font = Enum.Font.SourceSans
CloseBtn.TextSize = 18
CloseBtn.ZIndex = 5
CloseBtn.Parent = TopBar

local CollapseBtn = Instance.new("TextButton")
CollapseBtn.Size = UDim2.new(0, 28, 0, 28)
CollapseBtn.Position = UDim2.new(1, -56, 0, 0)
CollapseBtn.BackgroundTransparency = 1
ApplyFontLogic(CollapseBtn, "—")
CollapseBtn.TextColor3 = Theme.TextWhite
CollapseBtn.ZIndex = 5
CollapseBtn.Parent = TopBar

local Content = Instance.new("ScrollingFrame")
Content.Size = UDim2.new(1, 0, 1, -28)
Content.Position = UDim2.new(0, 0, 0, 28)
Content.BackgroundTransparency = 1
Content.BorderSizePixel = 0
Content.ScrollBarThickness = 4
Content.ScrollBarImageColor3 = Theme.Separator
Content.CanvasSize = UDim2.new(0, 0, 0, 0)
Content.AutomaticCanvasSize = Enum.AutomaticSize.Y
Content.ZIndex = 4
Content.Parent = GlobalCanvas
Window.Content = Content

local UIListLayout = Instance.new("UIListLayout")
UIListLayout.Padding = UDim.new(0, 8)
UIListLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
UIListLayout.SortOrder = Enum.SortOrder.LayoutOrder
UIListLayout.Parent = Content

local UIPadding = Instance.new("UIPadding")
UIPadding.PaddingTop = UDim.new(0, 8)
UIPadding.PaddingBottom = UDim.new(0, 8)
UIPadding.Parent = Content

local isCollapsed = false
CollapseBtn.MouseButton1Click:Connect(function()
	isCollapsed = not isCollapsed
	local targetSize = isCollapsed and UDim2.new(0, MainFrame.Size.X.Offset, 0, 28) or Window.Size
	TweenService:Create(MainFrame, tweenInfo, {Size = targetSize}):Play()
	ApplyFontLogic(CollapseBtn, isCollapsed and "▼" or "—")
	Content.Visible = not isCollapsed
end)

CloseBtn.MouseButton1Click:Connect(function()
	CloseBtn.Active = false
	CollapseBtn.Active = false
	for _, dp in pairs(Window.DropdownFrames) do
		dp:Destroy()
	end
	local t1 = TweenService:Create(MainFrame, tweenInfo, {Size = UDim2.new(0, MainFrame.Size.X.Offset, 0, 28)})
	t1:Play()
	t1.Completed:Connect(function()
		local t2 = TweenService:Create(GlobalCanvas, tweenInfo, {GroupTransparency = 1})
		t2:Play()
		t2.Completed:Connect(function()
			ScreenGui:Destroy()
		end)
	end)
end)

local dragging = false
local dragInput, dragStart, startPos

TopBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		dragStart = input.Position
		startPos = MainFrame.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
			end
		end)
	end
end)

TopBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
		dragInput = input
	end
end)

RunService.RenderStepped:Connect(function()
	if dragging and dragInput then
		local delta = dragInput.Position - dragStart
		local targetPos = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
		MainFrame.Position = MainFrame.Position:Lerp(targetPos, 0.16)
	end
	for _, dpData in pairs(Window.DropdownFrames) do
		if dpData.Frame.Visible then
			dpData.Frame.Position = UDim2.new(0, dpData.Ref.AbsolutePosition.X, 0, dpData.Ref.AbsolutePosition.Y + dpData.Ref.AbsoluteSize.Y)
		end
	end
end)

function Window:Delete(id)
	if Window.Elements[id] then
		Window.Elements[id].Container:Destroy()
		if Window.Elements[id].DropFrame then
			Window.Elements[id].DropFrame:Destroy()
			Window.DropdownFrames[id] = nil
		end
		Window.Elements[id] = nil
	end
end

function Window:AddToggle(opts)
	local id = opts.id or tostring(math.random(10000, 99999))
	local text = opts.text or "Toggle"
	local state = opts.state or false
	local callback = opts.callback or function() end

	local Wrapper = Instance.new("Frame")
	Wrapper.Size = UDim2.new(1, -20, 0, 22)
	Wrapper.BackgroundTransparency = 1
	Wrapper.ZIndex = 4
	Wrapper.Parent = Window.Content

	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(0, 50, 1, 0)
	Label.BackgroundTransparency = 1
	Label.Text = text
	Label.TextColor3 = Theme.TextWhite
	Label.Font = Enum.Font.SourceSans
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.ZIndex = 4
	Label.Parent = Wrapper

	local Box = Instance.new("Frame")
	Box.Size = UDim2.new(0, 22, 0, 22)
	Box.Position = UDim2.new(0, 60, 0, 0)
	Box.BackgroundColor3 = Theme.InputBG
	Box.BorderSizePixel = 0
	Box.ZIndex = 4
	Box.Parent = Wrapper
	ApplyStroke(Box)

	local Btn = Instance.new("TextButton")
	Btn.Size = UDim2.new(1, 0, 1, 0)
	Btn.BackgroundTransparency = 1
	Btn.Text = ""
	Btn.ZIndex = 5
	Btn.Parent = Box

	local Mark = Instance.new("TextLabel")
	Mark.Size = UDim2.new(1, 0, 1, 0)
	Mark.BackgroundTransparency = 1
	ApplyFontLogic(Mark, "✓")
	Mark.TextColor3 = Theme.Highlight
	Mark.Visible = state
	Mark.ZIndex = 5
	Mark.Parent = Box

	local element = { Container = Wrapper }
	local observer = nil

	function element:SetState(newState)
		state = newState
		Mark.Visible = state
		callback(state)
		if observer then observer(state) end
	end

	function element:Observe(obs)
		observer = obs
	end

	Btn.MouseButton1Click:Connect(function()
		element:SetState(not state)
	end)

	Window.Elements[id] = element
	return element
end

function Window:AddTextBox(opts)
	local id = opts.id or tostring(math.random(10000, 99999))
	local text = opts.text or ""
	local label = opts.text or "TextBox"
	local placeholder = opts.placeholder or ""
	local callback = opts.callback or function() end

	local Wrapper = Instance.new("Frame")
	Wrapper.Size = UDim2.new(1, -20, 0, 22)
	Wrapper.BackgroundTransparency = 1
	Wrapper.ZIndex = 4
	Wrapper.Parent = Window.Content

	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(0, 50, 1, 0)
	Label.BackgroundTransparency = 1
	Label.Text = label
	Label.TextColor3 = Theme.TextWhite
	Label.Font = Enum.Font.SourceSans
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.ZIndex = 4
	Label.Parent = Wrapper

	local Input = Instance.new("TextBox")
	Input.Size = UDim2.new(1, -60, 1, 0)
	Input.Position = UDim2.new(0, 60, 0, 0)
	Input.BackgroundColor3 = Theme.InputBG
	Input.BorderSizePixel = 0
	Input.Text = text
	Input.PlaceholderText = placeholder
	Input.TextColor3 = Theme.TextWhite
	Input.PlaceholderColor3 = Theme.TextDim
	Input.Font = Enum.Font.SourceSans
	Input.TextSize = 13
	Input.TextXAlignment = Enum.TextXAlignment.Left
	Input.ZIndex = 4
	Input.Parent = Wrapper
	ApplyStroke(Input)
	Instance.new("UIPadding", Input).PaddingLeft = UDim.new(0, 6)

	local element = { Container = Wrapper }
	local observer = nil

	function element:SetText(newText)
		Input.Text = newText
		callback(newText)
		if observer then observer(newText) end
	end

	function element:SetPlaceholder(newPlace)
		Input.PlaceholderText = newPlace
	end

	function element:Observe(obs)
		observer = obs
	end

	Input:GetPropertyChangedSignal("Text"):Connect(function()
		callback(Input.Text)
		if observer then observer(Input.Text) end
	end)

	Window.Elements[id] = element
	return element
end

