function Window:AddSlider(opts)
	local id = opts.id or tostring(math.random(10000, 99999))
	local label = opts.text or "Slider"
	local min = opts.min or 0
	local max = opts.max or 100
	local default = opts.default or min
	local callback = opts.callback or function() end

	local Wrapper = Instance.new("Frame")
	Wrapper.Size = UDim2.new(1, -20, 0, 22)
	Wrapper.BackgroundTransparency = 1
	Wrapper.ZIndex = 4
	Wrapper.Parent = Window.Content

	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(0, 50, 1, 0)
	Label.BackgroundTransparency = 1
	Label.Text = label
	Label.TextColor3 = Theme.TextWhite
	Label.Font = Enum.Font.SourceSans
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.ZIndex = 4
	Label.Parent = Wrapper

	local BG = Instance.new("Frame")
	BG.Size = UDim2.new(1, -60, 0, 8)
	BG.Position = UDim2.new(0, 60, 0.5, -4)
	BG.BackgroundColor3 = Theme.InputBG
	BG.BorderSizePixel = 0
	BG.ZIndex = 4
	BG.Parent = Wrapper
	ApplyStroke(BG)

	local Fill = Instance.new("Frame")
	Fill.Size = UDim2.new(0, 0, 1, 0)
	Fill.BackgroundColor3 = Theme.Highlight
	Fill.BorderSizePixel = 0
	Fill.ZIndex = 4
	Fill.Parent = BG

	local Knob = Instance.new("Frame")
	Knob.Size = UDim2.new(0, 12, 0, 16)
	Knob.Position = UDim2.new(0, -6, 0.5, -8)
	Knob.BackgroundColor3 = Theme.TextWhite
	Knob.BorderSizePixel = 0
	Knob.ZIndex = 5
	Knob.Parent = BG

	local Btn = Instance.new("TextButton")
	Btn.Size = UDim2.new(1, 20, 1, 20)
	Btn.Position = UDim2.new(0, -10, 0, -10)
	Btn.BackgroundTransparency = 1
	Btn.Text = ""
	Btn.ZIndex = 6
	Btn.Parent = BG

	local isSliding = false
	local currentValue = default
	local element = { Container = Wrapper }
	local observer = nil

	local function UpdateSliderLogic(percentage)
		percentage = math.clamp(percentage, 0, 1)
		Fill.Size = UDim2.new(percentage, 0, 1, 0)
		Knob.Position = UDim2.new(percentage, -6, 0.5, -8)
		currentValue = math.floor(min + ((max - min) * percentage))
		callback(currentValue)
		if observer then observer(currentValue) end
	end

	function element:SetValue(val)
		val = math.clamp(val, min, max)
		local percentage = (val - min) / (max - min)
		UpdateSliderLogic(percentage)
	end

	function element:Observe(obs)
		observer = obs
	end

	local function handleInput(input)
		local sizeX = BG.AbsoluteSize.X
		local posX = BG.AbsolutePosition.X
		local relativeX = input.Position.X - posX
		UpdateSliderLogic(relativeX / sizeX)
	end

	Btn.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isSliding = true
			handleInput(input)
		end
	end)

	UserInputService.InputChanged:Connect(function(input)
		if isSliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			handleInput(input)
		end
	end)

	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			isSliding = false
		end
	end)

	element:SetValue(default)
	Window.Elements[id] = element
	return element
end

function Window:AddDropdown(opts)
	local id = opts.id or tostring(math.random(10000, 99999))
	local label = opts.text or "Dropdown"
	local options = opts.options or {}
	local callback = opts.callback or function() end

	local Wrapper = Instance.new("Frame")
	Wrapper.Size = UDim2.new(1, -20, 0, 22)
	Wrapper.BackgroundTransparency = 1
	Wrapper.ZIndex = 4
	Wrapper.Parent = Window.Content

	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(0, 50, 1, 0)
	Label.BackgroundTransparency = 1
	Label.Text = label
	Label.TextColor3 = Theme.TextWhite
	Label.Font = Enum.Font.SourceSans
	Label.TextSize = 14
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.ZIndex = 4
	Label.Parent = Wrapper

	local MainBtn = Instance.new("TextButton")
	MainBtn.Size = UDim2.new(1, -60, 1, 0)
	MainBtn.Position = UDim2.new(0, 60, 0, 0)
	MainBtn.BackgroundColor3 = Theme.InputBG
	MainBtn.BorderSizePixel = 0
	MainBtn.Text = "Select..."
	MainBtn.TextColor3 = Theme.TextWhite
	MainBtn.Font = Enum.Font.SourceSans
	MainBtn.TextSize = 13
	MainBtn.TextXAlignment = Enum.TextXAlignment.Left
	MainBtn.ZIndex = 4
	MainBtn.Parent = Wrapper
	ApplyStroke(MainBtn)
	Instance.new("UIPadding", Input).PaddingLeft = UDim.new(0, 6)

	local Arrow = Instance.new("TextLabel")
	Arrow.Size = UDim2.new(0, 20, 1, 0)
	Arrow.Position = UDim2.new(1, -20, 0, 0)
	Arrow.BackgroundTransparency = 1
	ApplyFontLogic(Arrow, "▼")
	Arrow.TextColor3 = Theme.TextWhite
	Arrow.ZIndex = 5
	Arrow.Parent = MainBtn

	local DropFrame = Instance.new("ScrollingFrame")
	DropFrame.Size = UDim2.new(0, MainBtn.AbsoluteSize.X, 0, 0)
	DropFrame.BackgroundColor3 = Theme.InputBG
	DropFrame.BorderSizePixel = 0
	DropFrame.ScrollBarThickness = 4
	DropFrame.ScrollBarImageColor3 = Theme.Separator
	DropFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
	DropFrame.AutomaticCanvasSize = Enum.AutomaticSize.Y
	DropFrame.ClipsDescendants = true
	DropFrame.ZIndex = 10
	DropFrame.Visible = false
	DropFrame.Parent = ScreenGui
	ApplyStroke(DropFrame)
	
	Window.DropdownFrames[id] = {Frame = DropFrame, Ref = MainBtn}

	local List = Instance.new("UIListLayout", DropFrame)
	local currentVal = nil
	local element = { Container = Wrapper, DropFrame = DropFrame }
	local observer = nil

	local function ToggleDrop(open)
		if open then
			DropFrame.Visible = true
			DropFrame.Position = UDim2.new(0, MainBtn.AbsolutePosition.X, 0, MainBtn.AbsolutePosition.Y + MainBtn.AbsoluteSize.Y)
			DropFrame.Size = UDim2.new(0, MainBtn.AbsoluteSize.X, 0, 0)
			TweenService:Create(DropFrame, tweenInfo, {Size = UDim2.new(0, MainBtn.AbsoluteSize.X, 0, math.min(#options * 22, 110))}):Play()
		else
			local t = TweenService:Create(DropFrame, tweenInfo, {Size = UDim2.new(0, MainBtn.AbsoluteSize.X, 0, 0)})
			t:Play()
			t.Completed:Connect(function()
				if DropFrame.Size.Y.Offset == 0 then
					DropFrame.Visible = false
				end
			end)
		end
	end

	MainBtn.MouseButton1Click:Connect(function()
		ToggleDrop(not DropFrame.Visible or DropFrame.Size.Y.Offset == 0)
	end)

	local function BuildOptions()
		for _, v in pairs(DropFrame:GetChildren()) do
			if v:IsA("TextButton") then v:Destroy() end
		end
		checkMarks = {}
		for _, opt in ipairs(options) do
			if selected[opt] == nil then selected[opt] = false end
			local b = Instance.new("TextButton")
			b.Size = UDim2.new(1, 0, 0, 22)
			b.BackgroundTransparency = 1
			b.Text = "  " .. opt
			b.TextColor3 = Theme.TextWhite
			b.Font = Enum.Font.SourceSans
			b.TextSize = 13
			b.TextXAlignment = Enum.TextXAlignment.Left
			b.ZIndex = 11
			b.Parent = DropFrame

			local mk = Instance.new("TextLabel")
			mk.Size = UDim2.new(0, 22, 1, 0)
			mk.Position = UDim2.new(1, -22, 0, 0)
			mk.BackgroundTransparency = 1
			ApplyFontLogic(mk, "✓")
			mk.TextColor3 = Theme.Highlight
			mk.Visible = selected[opt]
			mk.ZIndex = 12
			mk.Parent = b
			checkMarks[opt] = mk

			b.MouseButton1Click:Connect(function()
				selected[opt] = not selected[opt]
				mk.Visible = selected[opt]
				UpdateText()
				callback(selected)
				if observer then observer(selected) end
			end)
		end
		UpdateText()
	end

	function element:SetOptions(newOpts)
		options = newOpts
		selected = {}
		BuildOptions()
	end

	function element:Select(optName, state)
		if type(state) ~= "boolean" then state = true end
		for _, v in ipairs(options) do
			if v == optName then
				selected[optName] = state
				if checkMarks[optName] then checkMarks[optName].Visible = state end
				UpdateText()
				callback(selected)
				if observer then observer(selected) end
				break
			end
		end
	end

	function element:AddOption(optName)
		table.insert(options, optName)
		BuildOptions()
	end

	function element:RemoveOption(optName)
		for i, v in ipairs(options) do
			if v == optName then
				table.remove(options, i)
				selected[optName] = nil
				break
			end
		end
		BuildOptions()
	end

	function element:Observe(obs)
		observer = obs
	end

	BuildOptions()
	Window.Elements[id] = element
	return element
end

return Window


end

return Library
